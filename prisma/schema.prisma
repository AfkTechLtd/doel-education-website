generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String           @id @default(cuid())
  supabaseId        String           @unique @map("supabase_id")
  email             String           @unique
  name              String
  role              Role             @default(STUDENT)
  avatarUrl         String?          @map("avatar_url")
  phone             String?
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  counselorNotes    CounselorNote[]
  receivedMessages  Message[]        @relation("ReceivedMessages")
  sentMessages      Message[]        @relation("SentMessages")
  notifications     Notification[]
  counselorStudents StudentProfile[] @relation("CounselorStudents")
  studentProfile    StudentProfile?

  @@index([supabaseId])
  @@index([email])
  @@map("users")
}

model StudentProfile {
  id            String         @id @default(cuid())
  userId        String         @unique @map("user_id")
  counselorId   String?        @map("counselor_id")
  nationality   String?
  dateOfBirth   DateTime?      @map("date_of_birth")
  passportNo    String?        @map("passport_no")
  phone         String?
  address       String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  kanbanStage   KanbanStage    @default(PENDING) @map("kanban_stage")
  application   Application?
  documentLinks DocumentLink[]
  documents     Document[]
  requirements   DocumentRequirement[]
  counselor     User?          @relation("CounselorStudents", fields: [counselorId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([counselorId])
  @@map("student_profiles")
}

