enum NotificationType {
  APPLICATION_UPDATE
  DOCUMENT_REQUEST
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  MESSAGE_RECEIVED
  COUNSELOR_ASSIGNED
  DEADLINE_REMINDER
  SYSTEM
}

enum CounselorNoteStage {
  INITIAL_CONSULTATION
  DOCUMENT_COLLECTION
  APPLICATION_PREP
  SUBMISSION
  VISA_PREP
  POST_ADMISSION
  COMPLETED
}

enum KanbanStage {
  NEW_DOCS
  PENDING
  APPLIED
  ADMITTED
  VISA_STAGE
}

enum ResourceType {
  SOP
  LOR
  AFFIDAVIT
}

enum DocumentLinkContext {
  REQUIRED_DOCUMENT
  APPLICATION_FIELD
  RESOURCE_TEMPLATE
}
