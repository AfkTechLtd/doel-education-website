// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Role {
  STUDENT
  COUNSELOR
  ADMIN
}

enum ApplicationStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
}

enum DocumentStatus {
  PENDING
  UPLOADED
  VERIFIED
  REJECTED
}

enum SectionNumber {
  SECTION_1
  SECTION_2
  SECTION_3
  SECTION_4
  SECTION_5
  SECTION_6
  SECTION_7
  SECTION_8
  SECTION_9
  SECTION_10
  SECTION_11
  SECTION_12
  SECTION_13
  SECTION_14
}

enum NotificationType {
  APPLICATION_UPDATE
  DOCUMENT_REQUEST
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  MESSAGE_RECEIVED
  COUNSELOR_ASSIGNED
  DEADLINE_REMINDER
  SYSTEM
}

enum CounselorNoteStage {
  INITIAL_CONSULTATION
  DOCUMENT_COLLECTION
  APPLICATION_PREP
  SUBMISSION
  VISA_PREP
  POST_ADMISSION
  COMPLETED
}

enum KanbanStage {
  NEW_DOCS
  PENDING
  APPLIED
  ADMITTED
  VISA_STAGE
}

// ============================================================
// Models
// ============================================================

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique @map("supabase_id")
  email       String   @unique
  name        String
  role        Role     @default(STUDENT)
  avatarUrl   String?  @map("avatar_url")
  phone       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  studentProfile    StudentProfile?
  counselorStudents StudentProfile[] @relation("CounselorStudents")
  sentMessages      Message[]        @relation("SentMessages")
  receivedMessages  Message[]        @relation("ReceivedMessages")
  notifications     Notification[]
  counselorNotes    CounselorNote[]

  @@index([supabaseId])
  @@index([email])
  @@map("users")
}

model StudentProfile {
  id           String       @id @default(cuid())
  userId       String       @unique @map("user_id")
  counselorId  String?      @map("counselor_id")
  kanbanStage  KanbanStage  @default(PENDING) @map("kanban_stage")
  nationality  String?
  dateOfBirth  DateTime?    @map("date_of_birth")
  passportNo   String?      @map("passport_no")
  phone        String?
  address      String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  counselor   User?          @relation("CounselorStudents", fields: [counselorId], references: [id], onDelete: SetNull)
  application Application?
  documents   Document[]

  @@index([counselorId])
  @@map("student_profiles")
}

model Application {
  id               String            @id @default(cuid())
  studentId        String            @unique @map("student_id")
  status           ApplicationStatus @default(NOT_STARTED)
  intendedProgram  String?           @map("intended_program")
  intendedUniversity String?         @map("intended_university")
  targetSemester   String?           @map("target_semester")
  targetYear       Int?              @map("target_year")
  completedSections Int              @default(0) @map("completed_sections")
  submittedAt      DateTime?         @map("submitted_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // Relations
  student  StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sections ApplicationSection[]

  @@index([studentId])
  @@map("applications")
}

model ApplicationSection {
  id            String        @id @default(cuid())
  applicationId String        @map("application_id")
  sectionNumber SectionNumber @map("section_number")
  data          Json          @default("{}")
  isComplete    Boolean       @default(false) @map("is_complete")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, sectionNumber])
  @@map("application_sections")
}

model Document {
  id          String         @id @default(cuid())
  studentId   String         @map("student_id")
  name        String
  type        String
  status      DocumentStatus @default(PENDING)
  storagePath String?        @map("storage_path")
  storageUrl  String?        @map("storage_url")
  bucket      String?
  mimeType    String?        @map("mime_type")
  sizeBytes   Int?           @map("size_bytes")
  notes       String?
  uploadedAt  DateTime?      @map("uploaded_at")
  verifiedAt  DateTime?      @map("verified_at")
  verifiedBy  String?        @map("verified_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@map("documents")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model CounselorNote {
  id          String             @id @default(cuid())
  studentId   String             @map("student_id")
  counselorId String             @map("counselor_id")
  stage       CounselorNoteStage
  content     String
  isPrivate   Boolean            @default(false) @map("is_private")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  // Relations
  counselor User @relation(fields: [counselorId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([counselorId])
  @@map("counselor_notes")
}

model ResourceTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   // "SOP" | "LOR" | "AFFIDAVIT" | "OTHER"
  content     String?
  fileUrl     String?  @map("file_url")
  isPublic    Boolean  @default(true) @map("is_public")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("resource_templates")
}
